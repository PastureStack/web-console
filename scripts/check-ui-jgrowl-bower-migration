#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PYCHECK'
import json
import re
import sys
from pathlib import Path

failures = 0


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
bower = json.loads(Path("bower.json").read_text(encoding="utf-8"))
build = Path("ember-cli-build.js").read_text(encoding="utf-8")
lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
lock = json.loads(lock_path.read_text(encoding="utf-8"))

dev_deps = package.get("devDependencies", {}) or {}
if dev_deps.get("jgrowl") != "1.4.2":
    fail("JGROWL_NPM_DEP_VERSION_UNEXPECTED", actual=dev_deps.get("jgrowl"), expected="1.4.2")
if "jgrowl" in (bower.get("dependencies", {}) or {}):
    fail("JGROWL_STILL_IN_BOWER_DEPENDENCIES")
for expected in ["node_modules/jgrowl/jquery.jgrowl.js", "node_modules/jgrowl/jquery.jgrowl.css"]:
    if expected not in build:
        fail("JGROWL_NPM_IMPORT_MISSING", path=expected)
for forbidden in ["bower_components/jgrowl/jquery.jgrowl.js", "bower_components/jgrowl/jquery.jgrowl.css"]:
    if forbidden in build:
        fail("JGROWL_BOWER_IMPORT_STILL_PRESENT", path=forbidden)

packages = lock.get("packages", {}) or {}
root_dev = (packages.get("", {}) or {}).get("devDependencies", {}) or {}
if root_dev.get("jgrowl") != "1.4.2":
    fail("JGROWL_LOCK_ROOT_VERSION_UNEXPECTED", actual=root_dev.get("jgrowl"), expected="1.4.2")
jgrowl_pkg = packages.get("node_modules/jgrowl", {}) or {}
if jgrowl_pkg.get("version") != "1.4.2":
    fail("JGROWL_LOCK_PACKAGE_VERSION_UNEXPECTED", actual=jgrowl_pkg.get("version"), expected="1.4.2")
if jgrowl_pkg.get("resolved") and "jgrowl/-/jgrowl-1.4.2.tgz" not in jgrowl_pkg.get("resolved", ""):
    fail("JGROWL_LOCK_RESOLVED_UNEXPECTED", resolved=jgrowl_pkg.get("resolved"))

jgrowl_usage_count = 0
for root in [Path("app"), Path("tests")]:
    if not root.exists():
        continue
    for path in root.rglob("*.js"):
        text = path.read_text(encoding="utf-8")
        jgrowl_usage_count += len(re.findall(r"\$\.jGrowl", text))
if jgrowl_usage_count < 3:
    fail("JGROWL_GLOBAL_USAGE_COUNT_TOO_LOW", actual=jgrowl_usage_count, minimum=3)

modernization = Path("docs/modernization.md").read_text(encoding="utf-8")
for phrase in ["No-Publish Bower jGrowl Migration Candidate", "jgrowl@1.4.2", "node_modules/jgrowl/jquery.jgrowl.js"]:
    if phrase not in modernization:
        fail("JGROWL_MIGRATION_DOC_MISSING", phrase=phrase)

node24_smoke = Path("scripts/node24-lock-smoke.js").read_text(encoding="utf-8")
for phrase in ["expectPackageJsonVersion(\"jgrowl\", \"1.4.2\")", "expectJGrowlBrowserGlobal", "jgrowl-global-smoke-ok"]:
    if phrase not in node24_smoke:
        fail("JGROWL_NODE24_LOCK_SMOKE_MISSING", phrase=phrase)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_JGROWL_BOWER_MIGRATION_OK jgrowl_usages={jgrowl_usage_count} lock={lock_path}")
print("failure_count=0")
PYCHECK
