#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PYCHECK'
import json
import re
import sys
from pathlib import Path

failures = 0


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
bower = json.loads(Path("bower.json").read_text(encoding="utf-8"))
build = Path("ember-cli-build.js").read_text(encoding="utf-8")
lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
lock = json.loads(lock_path.read_text(encoding="utf-8"))

dev_deps = package.get("devDependencies", {}) or {}
if dev_deps.get("lodash") != "3.10.1":
    fail("LODASH_NPM_DEP_VERSION_UNEXPECTED", actual=dev_deps.get("lodash"), expected="3.10.1")
if "lodash" in (bower.get("dependencies", {}) or {}):
    fail("LODASH_STILL_IN_BOWER_DEPENDENCIES")
if "node_modules/lodash/index.js" not in build:
    fail("LODASH_NPM_IMPORT_MISSING")
if "bower_components/lodash" in build:
    fail("LODASH_BOWER_IMPORT_STILL_PRESENT")

packages = lock.get("packages", {}) or {}
root_dev = (packages.get("", {}) or {}).get("devDependencies", {}) or {}
if root_dev.get("lodash") != "3.10.1":
    fail("LODASH_LOCK_ROOT_VERSION_UNEXPECTED", actual=root_dev.get("lodash"), expected="3.10.1")
lodash_pkg = packages.get("node_modules/lodash", {}) or {}
if lodash_pkg.get("version") != "3.10.1":
    fail("LODASH_LOCK_PACKAGE_VERSION_UNEXPECTED", actual=lodash_pkg.get("version"), expected="3.10.1")
if lodash_pkg.get("resolved") and "lodash/-/lodash-3.10.1.tgz" not in lodash_pkg.get("resolved", ""):
    fail("LODASH_LOCK_RESOLVED_UNEXPECTED", resolved=lodash_pkg.get("resolved"))

usage_count = 0
for root in [Path("app"), Path("addon"), Path("tests"), Path("vendor")]:
    if not root.exists():
        continue
    for path in root.rglob("*.js"):
        usage_count += len(re.findall(r"(^|[^A-Za-z0-9_$])_\.", path.read_text(encoding="utf-8")))
if usage_count < 20:
    fail("LODASH_GLOBAL_USAGE_COUNT_TOO_LOW", actual=usage_count, minimum=20)

modernization = Path("docs/modernization.md").read_text(encoding="utf-8")
for phrase in ["No-Publish Bower lodash Migration Candidate", "lodash@3.10.1", "node_modules/lodash/index.js"]:
    if phrase not in modernization:
        fail("LODASH_MIGRATION_DOC_MISSING", phrase=phrase)

node24_smoke = Path("scripts/node24-lock-smoke.js").read_text(encoding="utf-8")
for phrase in ["expectVersion(\"lodash\", \"3.10.1\")", "lodash-global-smoke-ok", "node_modules/lodash/index.js"]:
    if phrase not in node24_smoke:
        fail("LODASH_NODE24_LOCK_SMOKE_MISSING", phrase=phrase)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_LODASH_BOWER_MIGRATION_OK lodash_global_usages={usage_count} lock={lock_path}")
print("failure_count=0")
PYCHECK
