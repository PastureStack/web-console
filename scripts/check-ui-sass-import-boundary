    "app/styles/layout/flex-box": ['"table-border-color": $table-border-color'],
    "app/styles/components/growl": ['"brand-danger": $brand-danger'],
    "app/styles/components/resource-actions": ['"text-color": $text-color'],
    "app/styles/components/login": ['"primary": $primary'],
    "app/styles/components/progress-bar": ['"lightestGray": $lightestGray'],
    "app/styles/components/pod": ['"accent-one": $accent-one', '"border-radius-base": $border-radius-base', '"brand-primary-dark": $brand-primary-dark', '"btn-default-bg": $btn-default-bg', '"btn-default-color": $btn-default-color', '"lightGray": $lightGray', '"link-color": $link-color', '"link-hover-color": $link-hover-color', '"normal-weight": $normal-weight', '"table-bg": $table-bg', '"table-bg-accent": $table-bg-accent', '"table-border-color": $table-border-color', '"text-color": $text-color'],
    "app/styles/components/slider": ['"blueTwo": $blueTwo', '"lightGray": $lightGray', '"lightGrayDark": $lightGrayDark', '"midGray": $midGray', '"midGrayDark": $midGrayDark'],
    "app/styles/components/sortable": ['"lightGrayTwo": $lightGrayTwo', '"midGray": $midGray', '"midGrayDark": $midGrayDark', '"table-bg-hover": $table-bg-hover', '"well-bg": $well-bg'],
    "app/styles/components/spark-line": ['"blueDark": $blueDark', '"green": $green', '"table-bg-accent": $table-bg-accent', '"teal": $teal', '"yellowTwo": $yellowTwo'],
    "app/styles/components/multi-stats": ['"blueDark": $blueDark', '"green": $green', '"screen-sm-max": $screen-sm-max', '"screen-sm-min": $screen-sm-min', '"screen-xs-max": $screen-xs-max', '"shadow": $shadow', '"table-bg": $table-bg', '"table-border-color": $table-border-color', '"teal": $teal', '"yellow": $yellow', '"yellowDark": $yellowDark'],
    "app/styles/components/tooltip": ['"lightTeal": $lightTeal', '"lightTealDark": $lightTealDark', '"primary": $primary', '"primaryDark": $primaryDark', '"redDark": $redDark'],
    "app/styles/components/timeline": ['"lightGray": $lightGray', '"navyTwoDark": $navyTwoDark', '"orangeDark": $orangeDark'],
    "app/styles/components/github-avatar": ['"lightGray": $lightGray'],
    "app/styles/components/catalog-box": ['"accent-one": $accent-one', '"blueTwo": $blueTwo', '"greenTwo": $greenTwo', '"greenTwoDark": $greenTwoDark', '"icon-pasture-stack": $icon-pasture-stack', '"lightTeal": $lightTeal', '"lightTealDark": $lightTealDark', '"primary": $primary', '"primaryDark": $primaryDark', '"table-bg-accent": $table-bg-accent'],
    "app/styles/pages/loading": ['"midGray": $midGray', '"yellowDark": $yellowDark'],
    "app/styles/pages/fail-whale": ['"lightTeal": $lightTeal', '"teal": $teal'],
    "app/styles/pages/about": ['"bold-weight": $bold-weight', '"screen-sm-max": $screen-sm-max'],
    "app/styles/pages/welcome": ['"border-radius-large": $border-radius-large', '"brand-info": $brand-info', '"page-header-border-color": $page-header-border-color', '"well-bg": $well-bg'],
    "app/styles/pages/settings": ['"light-grey": $light-grey'],
    "app/styles/pages/catalog": ['"bold-weight": $bold-weight'],
    "app/styles/pages/service-addtl-info": ['"page-header-border-color": $page-header-border-color', '"red": $red', '"shadow": $shadow', '"tab-active-bg": $tab-active-bg', '"table-border-color": $table-border-color', '"well-bg": $well-bg'],
    "app/styles/pages/stack": ['"accent-three": $accent-three', '"accent-two": $accent-two', '"blueDark": $blueDark', '"bold-weight": $bold-weight', '"brand-danger": $brand-danger', '"brand-info": $brand-info', '"brand-success": $brand-success', '"brand-warning": $brand-warning', '"light-grey": $light-grey', '"midGray": $midGray', '"table-bg": $table-bg', '"table-bg-accent": $table-bg-accent', '"table-border-color": $table-border-color', '"text-color": $text-color', '"text-muted": $text-muted', '"well-bg": $well-bg'],
    "app/styles/layout/lg-screen": ['"screen-lg": $screen-lg'],
    "app/styles/layout/md-screen": ['"screen-md": $screen-md', '"screen-md-max": $screen-md-max'],
    "app/styles/layout/sm-screen": ['"lightGray": $lightGray', '"screen-sm": $screen-sm', '"screen-sm-max": $screen-sm-max', '"screen-xs": $screen-xs', '"table-border-color": $table-border-color'],
    "app/styles/layout/xs-screen": ['"accent-two": $accent-two', '"brand-info": $brand-info', '"link-color": $link-color', '"screen-xs-max": $screen-xs-max', '"table-border-color": $table-border-color', '"well-bg": $well-bg'],
}

import_re = re.compile(r'^\s*@import\s+["\']([^"\']+)["\'];\s*$')
load_css_re = re.compile(r'^\s*@include\s+meta\.load-css\(["\']([^"\']+)["\'](?:\s*,.*)?\);\s*$')
use_re = re.compile(r'^\s*@use\s+["\']([^"\']+)["\'](?:\s+as\s+(?:\*|[A-Za-z_-][\w-]*))?;\s*$')
global_dependency_re = re.compile(r"(?<![\w-])\$[A-Za-z_-][\w-]*|@include\s+|@extend\s+|^\s*@import\s+", re.M)
variable_re = re.compile(r"^\s*(\$[A-Za-z_-][\w-]*)\s*:", re.M)
bootstrap_config_key_re = re.compile(r'"([^"]+)":')


def variable_aliases(path, namespace):
    return [
        f"{name}: {namespace}.{name};"
        for name in variable_re.findall(Path(path).read_text(encoding="utf-8"))
    ]


compatibility_aliases = {
    "color": variable_aliases("app/styles/base/_colors.scss", "colors"),
    "icon": variable_aliases("vendor/icons/variables.scss", "icons"),
    "bootswatch": variable_aliases("vendor/bootswatch-cosmo/_variables.scss", "bootswatch"),
}

theme_aliases = {
    Path("app/styles/app-light.scss"): variable_aliases("app/styles/themes/_light.scss", "theme"),
    Path("app/styles/app-dark.scss"): variable_aliases("app/styles/themes/_dark.scss", "theme"),
}

bootstrap_default_only_variables = {
    "bootstrap-sass-asset-helper",
    "btn-border-radius-base",
    "btn-border-radius-large",
    "btn-border-radius-small",
    "form-group-margin-bottom",
    "zindex-modal-background",
    "nav-tabs-border-color",
    "nav-tabs-link-hover-border-color",
    "nav-tabs-active-link-hover-bg",
    "nav-tabs-active-link-hover-color",
    "nav-tabs-active-link-hover-border-color",
    "nav-tabs-justified-link-border-color",
    "nav-tabs-justified-active-link-border-color",
    "jumbotron-heading-font-size",
    "dl-horizontal-breakpoint",
}

bootstrap_variable_names = {
    name[1:]
    for name in variable_re.findall(
        Path("vendor/bootstrap-sass/assets/stylesheets/bootstrap/_variables.scss").read_text(encoding="utf-8")
    )
}
bootstrap_config_expected = bootstrap_variable_names - bootstrap_default_only_variables


def bootstrap_config_keys(source):
    match = re.search(r"\$bootstrap-config:\s*\((.*?)\);", source, re.S)
    if not match:
        return set()
    return set(bootstrap_config_key_re.findall(match.group(1)))


def app_style_partial(import_name):
    if not import_name.startswith("app/styles/"):
        return None
    parts = Path(import_name)
    return Path(*parts.parts[:-1]) / f"_{parts.name}.scss"


def remaining_import_class(import_name):
    if import_name.startswith(("vendor/", "app/styles/base/", "app/styles/helpers/")):
        return "foundation"
    if import_name.startswith("app/styles/themes/"):
        return "theme"
    if not import_name.startswith("app/styles/"):
        return "vendor"

    path = app_style_partial(import_name)
    if path is None or not path.is_file():
        return "missing"

    source = path.read_text(encoding="utf-8")
    stripped_source = "\n".join(
        line for line in source.splitlines()
        if not line.strip().startswith("//")
    )
    if not global_dependency_re.search(stripped_source):
        return "css-only"
    return "global-dependent"

failures = []
class_counts = {}
boundary_counts = {}

for path, expected_imports in entrypoints.items():
    if not path.is_file():
        failures.append(f"SASS_IMPORT_ENTRYPOINT_MISSING file={path}")
        continue

    imports = []
    load_css = []
    uses = []
    load_css_lines = {}
    for number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        import_match = import_re.match(line)
        if import_match:
            imports.append(import_match.group(1))
        elif "@import" in line:
            failures.append(f"SASS_IMPORT_UNPARSED file={path}:{number} line={line.strip()}")

        load_css_match = load_css_re.match(line)
        if load_css_match:
            load_css.append(load_css_match.group(1))
            load_css_lines[load_css_match.group(1)] = line.strip()

        use_match = use_re.match(line)
        if use_match:
            uses.append(use_match.group(1))

    if imports != expected_imports:
        failures.append(
            f"SASS_IMPORT_BOUNDARY_CHANGED file={path} expected_count={len(expected_imports)} actual_count={len(imports)}"
        )
        missing = [item for item in expected_imports if item not in imports]
        extra = [item for item in imports if item not in expected_imports]
        if missing:
            failures.append(f"SASS_IMPORT_BOUNDARY_MISSING file={path} imports={','.join(missing)}")
        if extra:
            failures.append(f"SASS_IMPORT_BOUNDARY_EXTRA file={path} imports={','.join(extra)}")

    if load_css != load_css_expected:
        failures.append(
            f"SASS_LOAD_CSS_BOUNDARY_CHANGED file={path} expected_count={len(load_css_expected)} actual_count={len(load_css)}"
        )

    expected_uses = use_expected[path]
    if uses != expected_uses:
        failures.append(
            f"SASS_USE_BOUNDARY_CHANGED file={path} expected_count={len(expected_uses)} actual_count={len(uses)}"
        )
        missing_uses = [item for item in expected_uses if item not in uses]
        extra_uses = [item for item in uses if item not in expected_uses]
        if missing_uses:
            failures.append(f"SASS_USE_BOUNDARY_MISSING file={path} uses={','.join(missing_uses)}")
        if extra_uses:
            failures.append(f"SASS_USE_BOUNDARY_EXTRA file={path} uses={','.join(extra_uses)}")

    for name, expected_configs in configured_load_css_expected.items():
        line = load_css_lines.get(name, "")
        for expected_config in expected_configs:
            if expected_config not in line:
                failures.append(f"SASS_CONFIGURED_LOAD_CSS_MISSING file={path} import={name} expected={expected_config}")

    source = path.read_text(encoding="utf-8")
    actual_bootstrap_config_keys = bootstrap_config_keys(source)
    if not actual_bootstrap_config_keys:
        failures.append(f"SASS_BOOTSTRAP_CONFIG_MISSING file={path}")
    else:
        missing_bootstrap_config = sorted(bootstrap_config_expected - actual_bootstrap_config_keys)
        extra_bootstrap_config = sorted(actual_bootstrap_config_keys - bootstrap_config_expected)
        if missing_bootstrap_config:
            failures.append(
                f"SASS_BOOTSTRAP_CONFIG_MISSING_KEYS file={path} keys={','.join(missing_bootstrap_config)}"
            )
        if extra_bootstrap_config:
            failures.append(
                f"SASS_BOOTSTRAP_CONFIG_EXTRA_KEYS file={path} keys={','.join(extra_bootstrap_config)}"
            )

    for alias_type, expected_aliases in compatibility_aliases.items():
        for expected_alias in expected_aliases:
            if expected_alias not in source:
                failures.append(f"SASS_{alias_type.upper()}_ALIAS_MISSING file={path} expected={expected_alias}")
    for expected_alias in theme_aliases[path]:
        if expected_alias not in source:
            failures.append(f"SASS_THEME_ALIAS_MISSING file={path} expected={expected_alias}")

    for import_name in imports:
        import_class = remaining_import_class(import_name)
        class_counts[import_class] = class_counts.get(import_class, 0) + 1
        boundary = expected_remaining_import_boundaries.get(import_name)
        if boundary is None:
            failures.append(f"SASS_REMAINING_IMPORT_BOUNDARY_UNKNOWN file={path} import={import_name}")
        else:
            boundary_counts[boundary] = boundary_counts.get(boundary, 0) + 1
        if import_class == "missing":
            failures.append(f"SASS_IMPORT_PARTIAL_MISSING file={path} import={import_name}")
        elif import_class == "css-only":
            failures.append(f"SASS_IMPORT_CSS_ONLY_LEAF_STILL_PINNED file={path} import={import_name}")

if failures:
    for failure in failures:
        print(failure)
    print(f"failure_count={len(failures)}")
    sys.exit(1)

print("UI_SASS_IMPORT_BOUNDARY_OK entrypoints=2 remaining_imports_per_entrypoint=0 load_css_per_entrypoint=49 use_per_entrypoint=7")
print("remaining_import_classes=" + (",".join(f"{name}:{count}" for name, count in sorted(class_counts.items())) or "none"))
print("remaining_import_boundaries=" + (",".join(f"{name}:{count}" for name, count in sorted(boundary_counts.items())) or "none"))
print(f"bootstrap_config_keys={len(bootstrap_config_expected)} bootstrap_default_only_keys={len(bootstrap_default_only_variables)}")
print("No Sass @import remains in the app-light/app-dark entrypoint boundary; vendored Bootstrap internals remain separately tracked.")
print("Configured sass:meta.load-css migrations must keep explicit theme variable injection; do not rely on hidden global Sass scope.")
print("No CSS-only app stylesheet partial remains pinned to @import; new CSS-only leaf imports must use sass:meta.load-css.")
print("Bootstrap now loads through sass:meta.load-css with explicit configuration and a root compatibility bridge.")
print("Cross-module @extend bridges must stay explicit until selector-provider redesign proves byte-identical CSS.")
print("failure_count=0")
PY
