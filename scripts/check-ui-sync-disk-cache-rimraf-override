#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PY'
import json
import sys
from pathlib import Path

failures = 0


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
sync_disk_cache_override = (package.get("overrides", {}) or {}).get("sync-disk-cache", {}) or {}
if sync_disk_cache_override.get("rimraf") != "6.1.3":
    fail(
        "SYNC_DISK_CACHE_RIMRAF_OVERRIDE_UNEXPECTED",
        actual=sync_disk_cache_override.get("rimraf"),
        expected="6.1.3",
    )

lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
if not lock_path.is_file():
    fail("MISSING_SASS_REPLACEMENT_LOCK", file=lock_path)
else:
    lock = json.loads(lock_path.read_text(encoding="utf-8"))
    packages = lock.get("packages", {}) or {}
    sync_disk_cache = packages.get("node_modules/sync-disk-cache", {})
    rimraf = packages.get("node_modules/sync-disk-cache/node_modules/rimraf") or packages.get("node_modules/rimraf", {})
    if sync_disk_cache.get("version") != "2.1.0":
        fail("SYNC_DISK_CACHE_LOCK_VERSION_UNEXPECTED", actual=sync_disk_cache.get("version"), expected="2.1.0")
    if rimraf.get("version") != "6.1.3":
        fail("SYNC_DISK_CACHE_RIMRAF_LOCK_VERSION_UNEXPECTED", actual=rimraf.get("version"), expected="6.1.3")
    for removed in [
        "node_modules/sync-disk-cache/node_modules/glob",
        "node_modules/sync-disk-cache/node_modules/inflight",
    ]:
        if removed in packages:
            fail("SYNC_DISK_CACHE_LEGACY_DEPENDENCY_REMAINS", package=removed, version=packages[removed].get("version"))
    package_count = len(packages)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(
    "UI_SYNC_DISK_CACHE_RIMRAF_OVERRIDE_OK "
    f"sync-disk-cache=2.1.0 rimraf=6.1.3 lockfile={lock_path} package_count={package_count}"
)
print("The no-publish sync-disk-cache path resolves maintained rimraf 6.1.3 and no longer carries its nested legacy glob/inflight path.")
print("failure_count=0")
PY
