#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PY'
import json
import sys
from pathlib import Path

failures = 0


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


removed_addons = {
    "ember-cli-jshint",
    "broccoli-jshint",
    "jshint",
    "ember-cli-release",
}
package = json.loads(Path("package.json").read_text(encoding="utf-8"))
for section in ("dependencies", "devDependencies", "overrides"):
    values = package.get(section, {}) or {}
    for name in sorted(removed_addons):
        if name in values:
            fail("LEGACY_DEV_ADDON_PRESENT_IN_PACKAGE", section=section, package=name)

lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
if not lock_path.is_file():
    fail("MISSING_PACKAGE_LOCK", file=lock_path)
    package_count = 0
else:
    lock = json.loads(lock_path.read_text(encoding="utf-8"))
    packages = lock.get("packages", {})
    root = packages.get("", {})
    for field in ("dependencies", "devDependencies", "engines"):
        if package.get(field, {}) != root.get(field, {}):
            fail("PACKAGE_LOCK_ROOT_FIELD_DRIFT", field=field)
    for package_path in sorted(packages):
        for name in removed_addons:
            if package_path.endswith("node_modules/" + name) or f"node_modules/{name}/" in package_path:
                fail("LEGACY_DEV_ADDON_PRESENT_IN_LOCK", package=name, path=package_path)
    package_count = len(packages)

for path in [Path(".jshintrc"), Path("blueprints/.jshintrc"), Path("server/.jshintrc"), Path("tests/.jshintrc")]:
    if path.exists():
        fail("LEGACY_JSHINTRC_PRESENT", file=path)

active_paths = [
    Path("app/components/container-shell/component.js"),
    Path("config/environment.js"),
    Path("config/ember-intl.js"),
    Path("ember-cli-build.js"),
    Path("testem.js"),
]
for path in active_paths:
    text = path.read_text(encoding="utf-8")
    if "jshint" in text.lower():
        fail("LEGACY_JSHINT_MARKER_PRESENT", file=path)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_LEGACY_DEV_ADDON_REMOVAL_OK lockfile={lock_path} package_count={package_count}")
print("ember-cli-jshint, broccoli-jshint, jshint, and ember-cli-release are absent from the current no-publish UI graph.")
print("failure_count=0")
PY
