#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PY'
import json
import subprocess
import sys
from pathlib import Path

failures = 0


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
for field in ("dependencies", "devDependencies", "optionalDependencies"):
    if "dompurify" in package.get(field, {}):
        fail("DOMPURIFY_STILL_DECLARED", field=field)

search_targets = ["app", "addon", "lib", "tests", "config", "public"]
existing_targets = [target for target in search_targets if Path(target).exists()]
if existing_targets:
    result = subprocess.run(
        ["grep", "-RInE", "dompurify|DOMPurify", *existing_targets],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    if result.stdout.strip():
        print(result.stdout.rstrip())
        fail("DOMPURIFY_SOURCE_REFERENCE_STILL_PRESENT")

lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
if not lock_path.is_file():
    fail("MISSING_PACKAGE_LOCK", file=lock_path)
else:
    lock = json.loads(lock_path.read_text(encoding="utf-8"))
    packages = lock.get("packages", {})
    root = packages.get("", {})
    for field in ("dependencies", "devDependencies", "engines"):
        if package.get(field, {}) != root.get(field, {}):
            fail("PACKAGE_LOCK_ROOT_FIELD_DRIFT", field=field)
    for package_path in packages:
        if package_path.endswith("node_modules/dompurify"):
            fail("DOMPURIFY_STILL_RESOLVED", package=package_path)
    package_count = len(packages)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_DOMPURIFY_REMOVAL_OK lockfile={lock_path} package_count={package_count}")
print("dompurify was an unused direct UI dependency in the no-publish graph; no source import or lock resolution remains.")
print("failure_count=0")
PY
