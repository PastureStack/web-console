#!/usr/bin/env bash
set -euo pipefail

cat >&2 <<'EOF'
scripts/package-novnc is disabled in the rc16 maintenance source tree.

The active UI source imports the checked-in vendor/novnc.js bundle. The old
packager depended on the old noVNC Bower directory, which is intentionally no longer
part of bower.json. Rebuilding or replacing noVNC must be done in a dedicated
compatibility-gated migration with console/browser regression coverage.
EOF
exit 1
