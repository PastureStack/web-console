const momentLocaleMap = {
  'de-de': 'de', 'fa-ir': 'fa', 'fil-ph': 'tl-ph', 'fr-fr': 'fr',
  'hu-hu': 'hu', 'ja-jp': 'ja', 'ko-kr': 'ko', 'pt-br': 'pt-br',
  'ru-ru': 'ru', 'uk-ua': 'uk', 'zh-hans': 'zh-cn', 'zh-tw': 'zh-tw'
};
Object.entries(momentLocaleMap).forEach(([locale, momentLocale]) => {
  if (!languageSource.includes(`'${locale}': '${momentLocale}'`)) {
    failures.push(`missing_moment_mapping=${locale}`);
  }
  if (!buildSource.includes(`moment/locale/${momentLocale}.js`)) {
    failures.push(`missing_moment_bundle=${locale}`);
  }
});
if (!dateTimeSource.includes("resolvedFormat = 'LL LTS'")) {
  failures.push('missing_localized_date_time_format');
}
if (!dateTimeSource.includes("resolvedFormat = 'LTS'")) {
  failures.push('missing_localized_time_format');
}
if (!dateTimeSource.includes("PHILIPPINES_DATE_TIME_FORMAT = 'LL h:mm:ss A'") ||
    !dateTimeSource.includes("PHILIPPINES_TIME_FORMAT = 'h:mm:ss A'")) {
  failures.push('missing_philippines_12_hour_format');
}
if (!dateTimeSource.includes('moment(value).locale(locale).format(resolvedFormat)')) {
  failures.push('date_formatter_does_not_refresh_active_locale');
}
if (!buildSource.includes("app.import('vendor/moment-default-locale.js');") ||
    !fs.readFileSync(path.join(repoRoot, 'vendor', 'moment-default-locale.js'), 'utf8').includes("moment.locale('en');")) {
  failures.push('missing_deterministic_default_moment_locale');
}
if (!infoMultiStatsSource.includes("intl').t('infoMultiStats.time.now'") ||
    /return ['"]Now['"]| min, .* sec ago|pluralize\(.*(?:minute|second)/u.test(infoMultiStatsSource)) {
  failures.push('unlocalized_relative_time=utilization_graph');
}
if (!serviceLogSource.includes('formatDurationSeconds(sec)') ||
    !serviceLogSource.includes("intl').t('serviceLog.running'") ||
    /return sec \+ ["'] sec["']|return ["']Running["']/u.test(serviceLogSource)) {
  failures.push('unlocalized_runtime=service_log');
}
if (!portModelSource.includes("intl').t('formatIp.unknownIp'") ||
    !portModelSource.includes("intl').t('generic.loading'") ||
    /Unknown IP|return ["']Loading\.\.\.["']/u.test(portModelSource)) {
  failures.push('unlocalized_status=port_model');
}

if (failures.length > 0) {
  failures.slice(0, 300).forEach((failure) => console.error(`UI_LOCALIZATION_ERROR ${failure}`));
  if (failures.length > 300) {
    console.error(`UI_LOCALIZATION_ERROR additional_failures=${failures.length - 300}`);
  }
  console.error(`UI_LOCALIZATION_FAILURE_COUNT=${failures.length}`);
  process.exit(1);
}

console.log(
  `UI_LOCALIZATION_OK locales=${requiredLocales.length} ` +
  `english_leaves=${Object.keys(englishLeaves).length} missing=0 orphan=0 invalid_icu=0`
);
