if (englishLeaves.languageName !== 'English (United States)') {
  failures.push('unexpected_value=en-us:languageName');
}
Object.entries(englishLeaves).forEach(([key, value]) => {
  if (typeof value === 'string' && /\b(?:rancher(?:\s+labs)?|suse)\b/iu.test(value)) {
    failures.push(`obsolete_visible_brand=en-us:${key}`);
  }
});
if (/target="_blank"(?!\s+rel="noopener noreferrer")/u.test(englishSource)) {
  failures.push('unsafe_external_link=en-us');
}
if (/\bCattle\b/u.test(englishSource)) {
  failures.push('obsolete_visible_component_name=en-us');
}
[
  ['modalAboutComponent.cattle', 'Orchestration Engine'],
  ['modalAboutComponent.machineService', 'Host Provisioner'],
].forEach(([key, expected]) => {
  if (englishLeaves[key] !== expected) {
    failures.push(`unexpected_value=en-us:${key}`);
  }
});

const semanticFalseFriends = {
  'de-de': /\b(?:Hinrichtung eines Kindes|Umwelt|Bild(?:er|es)?)\b/u,
  'fa-ir': /(?:اعدام کودک|محیط زیست|حسابرسی|رنچر|ظرف|اهراز|مشکشلات|همهow|Availablility)/u,
  'fil-ph': /\b(?:lalagyan|larawan)\b|layunin-built|hindi kilalang impormasyon|Kubernetes Ang dashboard/iu,
  'fr-fr': /(?:Exécution d'enfants|ui-pilote-skel|\b[Pp]iles?\b)/u,
  'hu-hu': /(?:Gyermek kivégzés|Hozzáférési naplók)/u,
  'pt-br': /(?:Execução infantil|Meio Ambiente|\b[Pp]ilhas?\b)/u,
  'ru-ru': /(?:Детская казнь|Окружающая среда|окружающая среда)/u,
  'uk-ua': /(?:Дитяча страта|Навколишнє середовище)/u,
  'zh-hans': /(?:处决儿童|工艺流程)/u,
};

// These fragments lock the natural word order around the host warning's
// embedded documentation link. Translating the linked words and the trailing
// sentence independently previously produced grammatically broken banners in
// nearly every locale even though all translation keys were present.
const regionalNoHostsFragments = {
  'de-de': 'Leitfaden zur Docker-Kompatibilität</a>:',
  'fa-ir': 'راهنمای سازگاری Docker</a> را بررسی کنید:',
  'fil-ph': 'gabay sa compatibility ng Docker</a>:',
  'fr-fr': 'instructions de compatibilité Docker</a> :',
  'hu-hu': 'Docker-kompatibilitási útmutatót</a>:',
  'ja-jp': 'Docker の互換性ガイド</a>をご確認ください：',
  'ko-kr': 'Docker 호환성 안내</a>를 먼저 확인하세요:',
  'pt-br': 'orientações de compatibilidade do Docker</a>:',
  'ru-ru': 'руководством по совместимости Docker</a>:',
  'uk-ua': 'настановами щодо сумісності з Docker</a>:',
  'zh-hans': 'Docker 兼容性说明</a>：',
  'zh-tw': 'Docker 相容性說明</a>：',
};

const exactEnglishAllowlist = new Set([
  'PastureStack', 'GitHub', 'Docker', 'Kubernetes', 'Mesos', 'Swarm', 'Compose',
  'Convoy', 'OpenLDAP', 'Active Directory', 'API', 'CLI', 'ID', 'UUID', 'URL',
  'URI', 'IP', 'FQDN', 'HTTP', 'HTTPS', 'TCP', 'UDP', 'TLS', 'SSL', 'LDAP',
  'YAML', 'JSON', 'CPU', 'vCPU', 'vCPUs', 'RAM', 'mCPU', 'TTY', 'NAT', 'DNS',
  'MB', 'GB', 'ms', 'N/A', 'n/a', 'Mac OS X', 'Windows', 'Linux', 'Helm', 'Cattle',
  'docker-compose.yml', 'haproxy.cfg', 'answers.txt',
  'TTY <span class="text-muted">(-t)</span>', 'Alibaba Cloud Docker Hub'
]);

// An exact English value is accepted only when every word is part of a
// reviewed technical vocabulary. This deliberately does not include general
// interface verbs such as add, move, run, remove, report, or log out. The
// previous "three words or fewer" shortcut allowed hundreds of untranslated
// buttons and table labels to pass unnoticed.
const technicalEnglishTokens = new Set(`
  access control key keys username password secret secrets token api endpoint
  environment domain name authorization callback authentication active
  directory azure ad github enterprise nfs server catalog shell algorithm
  serial number ip ips address stats cpu cpus network host docker id entry
  point entrypoint networking health check protocol mount snapshot timeline
  error port provider custom kernel os mcpu kubernetes dashboard ui cli driver
  checksum mesos template email fqdn scale global log load balancer tag
  variable virtual machine vm ldap tls uid distinguishedname service alias helm
  container standard out tty file mode pid memory limit pinning hyperv prefix
  target source batch interval sec vcpus volume receiver hooks display resource
  group node cluster clusterip root disk data center pool availability available
  zone ami iam profile subnet vpc vnet subscription openstack remote reseller
  metadata xml namespace admin component compose user interface timeout stack
  trace sidekick classic portainer link graph default region image images
  isolation native engine pools status system team transparent version webhooks
  generation details agent backend branch info upgrade console total action
  actions date documentation instance message label route rc windows linux mac
  swarm pasturestack orchestration provisioner shibboleth mknod pod
  azurepubliccloud usr aliyun slb cidr hub yaml type vcenter ssh scheduler
  registry reinitializing public certs internet max bandwidth backup read only
  ec tags map trigger chain url hostname vswitch login beta set octal v
`.trim().split(/\s+/u));

const localeIdenticalEnglishWords = {
  'de-de': new Set([
    'Details', 'Generation', 'in', 'In:', 'Isolation', 'Links', 'Name',
    'Service', 'Status', 'System', 'Team', 'Transparent', 'Version', 'Zone'
  ]),
  'fr-fr': new Set([
    'Action', 'Actions', 'Console', 'Date', 'Documentation', 'Instance',
    'Message', 'Mode', 'Orchestration', 'Port', 'Ports', 'Secret', 'Secrets',
    'Service', 'Stacks', 'Total', 'Variable', 'Version', 'Volumes', 'Zone'
  ]),
  'pt-br': new Set(['Stack:', 'Stacks', 'Total', 'Volumes', 'Webhooks']),
};

const machineContractKeys = [
  'machine.driverCustom.windows.step2Copy',
  'machine.driverCustom.windowsSteps.step2Copy',
  'machine.driverAzure.resourceGroup.placeholder',
];

const mixedLanguageAllowlist = new Set([
  ...machineContractKeys,
  'formCommand.command.placeholder',
  'formVolumes.pathPlaceholder',
  'machine.driverCustom.windows.step2Copy',
  'machine.driverCustom.windowsSteps.step2Copy',
]);

function containsLongLatinPhrase(value) {
  const stripped = value
    .replace(/<code>[\s\S]*?<\/code>/giu, ' ')
    .replace(/<[^>]+>/gu, ' ')
    .replace(/https?:\/\/\S+/giu, ' ')
    .replace(/\{[^{}]+\}/gu, ' ')
    .replace(/\b(?:PastureStack|Docker|GitHub|Linux|Windows|API|CLI|DNS|HTTP|HTTPS|SSH|SSL|TLS|URL|ID|IP|FQDN|YAML|JSON|CPU|RAM|Kubernetes|Mesos|Swarm|Compose|EC2|VPC|Availability Zone|Web Console|Host Provisioner|Orchestration Engine|Server Name Indication|Network Policy Manager|MyApp|John Smith)\b/giu, ' ');

  return /\b[A-Za-z]+(?:[ /&-]+[A-Za-z]+){3,}\b/u.test(stripped);
}

const localeScriptPatterns = {
  'fa-ir': /[\u0600-\u06FF]/u,
  'ja-jp': /[\u3040-\u30FF\u3400-\u9FFF]/u,
  'ko-kr': /[\uAC00-\uD7AF]/u,
  'ru-ru': /[\u0400-\u04FF]/u,
  'uk-ua': /[\u0400-\u04FF]/u,
  'zh-hans': /[\u3400-\u9FFF]/u,
  'zh-tw': /[\u3400-\u9FFF]/u,
};

function flatten(value, prefix = '', result = {}) {
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    Object.keys(value).forEach((key) => {
      flatten(value[key], prefix ? `${prefix}.${key}` : key, result);
    });
  } else {
    result[prefix] = value;
  }
  return result;
}

function collectArguments(ast, result = new Set()) {
  (ast.elements || []).forEach((element) => {
    if (element.type === 'argumentElement') {
      result.add(element.id);
      if (element.format && element.format.options) {
        element.format.options.forEach((option) => collectArguments(option.value, result));
      }
    }
  });
  return result;
}

function messageArguments(message) {
  return [...collectArguments(messageParser.parse(message))].sort();
}

function duplicateMappingKeys(source) {
  const levels = [];
  const seen = new Set();
  const duplicates = [];
  source.split(/\r?\n/u).forEach((line) => {
    const match = line.match(/^(\s*)(?:"([^"]+)"|'([^']+)'|([A-Za-z0-9_.-]+)):\s*/u);
    if (!match) {
      return;
    }
    const indent = match[1].length;
    const key = match[2] || match[3] || match[4];
    while (levels.length > 0 && levels[levels.length - 1].indent >= indent) {
      levels.pop();
    }
    const fullKey = [...levels.map((level) => level.key), key].join('.');
    if (seen.has(fullKey)) {
      duplicates.push(fullKey);
    }
    seen.add(fullKey);
    levels.push({ indent, key });
  });
  return duplicates;
}

function allowedExactEnglish(value, key, locale) {
  const trimmed = value.trim();
  if (!/[A-Za-z]/.test(trimmed) || exactEnglishAllowlist.has(trimmed)) {
    return true;
  }
  if ((localeIdenticalEnglishWords[locale] || new Set()).has(trimmed)) {
    return true;
  }
  if (machineContractKeys.includes(key)) {
    return true;
  }
  if (/^(?:https?:\/\/|\/|[A-Za-z]:\\)/.test(trimmed)) {
    return true;
  }
  if (/^[A-Z0-9_.:+/#%()\[\]{}<>=,&;'" -]+$/.test(trimmed)) {
    return true;
  }
  if (/^[\w.-]+\.(?:ya?ml|json|cfg|conf|txt|iso|img|tar|gz|zip)$/i.test(trimmed)) {
    return true;
  }
  if (/^\{[A-Za-z_][A-Za-z0-9_]*\}(?: \(\{[A-Za-z_][A-Za-z0-9_]*\}\))?$/.test(trimmed)) {
    return true;
  }
  const withoutArguments = trimmed.replace(/\{[^{}]+\}/gu, '');
  if (!/[A-Za-z]/u.test(withoutArguments)) {
    return true;
  }
  const words = withoutArguments
    .replace(/<[^>]+>/gu, ' ')
    .match(/[A-Za-z]+/gu) || [];

  return words.length > 0 && words.every((word) => technicalEnglishTokens.has(word.toLowerCase()));
}

requiredLocales.forEach((locale) => {
  const localePath = path.join(translationsDir, `${locale}.yaml`);
  if (!fs.existsSync(localePath)) {
    failures.push(`missing_locale=${locale}`);
    return;
  }
  const source = fs.readFileSync(localePath, 'utf8');
  let values;
  try {
    values = YAML.load(localePath);
  } catch (error) {
    failures.push(`invalid_yaml=${locale}:${error.message}`);
    return;
  }
  const leaves = flatten(values);
  duplicateMappingKeys(source).forEach((key) => failures.push(`duplicate_key=${locale}:${key}`));

  if (/target="_blank"(?!\s+rel="noopener noreferrer")/u.test(source)) {
    failures.push(`unsafe_external_link=${locale}`);
  }
  if (/\bCattle\b/u.test(source)) {
    failures.push(`obsolete_visible_component_name=${locale}`);
  }
  if (semanticFalseFriends[locale] && semanticFalseFriends[locale].test(source)) {
    failures.push(`semantic_false_friend=${locale}`);
  }

  Object.entries(leaves).forEach(([key, value]) => {
    if (typeof value === 'string' && /\b(?:rancher(?:\s+labs)?|suse)\b/iu.test(value)) {
      failures.push(`obsolete_visible_brand=${locale}:${key}`);
    }
  });

  Object.keys(englishLeaves).forEach((key) => {
    const englishValue = englishLeaves[key];
    const localizedValue = leaves[key];
    if (!(key in leaves)) {
      failures.push(`missing_key=${locale}:${key}`);
      return;
    }
    if (typeof englishValue === 'string' && englishValue !== '') {
      if (typeof localizedValue !== 'string' || localizedValue === '') {
        failures.push(`empty_value=${locale}:${key}`);
        return;
      }
      try {
        const expectedArguments = messageArguments(englishValue);
        const actualArguments = messageArguments(localizedValue);
        if (JSON.stringify(expectedArguments) !== JSON.stringify(actualArguments)) {
          failures.push(`argument_mismatch=${locale}:${key}`);
        }
      } catch (error) {
        failures.push(`invalid_icu=${locale}:${key}`);
      }
      if (localizedValue.trim() === englishValue.trim() && !allowedExactEnglish(localizedValue, key, locale)) {
        failures.push(`untranslated_value=${locale}:${key}`);
      }
      if (localeScriptPatterns[locale] && localeScriptPatterns[locale].test(localizedValue) &&
          !mixedLanguageAllowlist.has(key) && containsLongLatinPhrase(localizedValue)) {
        failures.push(`mixed_language_phrase=${locale}:${key}`);
      }
    }
  });

  Object.keys(leaves).filter((key) => !(key in englishLeaves)).forEach((key) => {
    failures.push(`orphan_key=${locale}:${key}`);
  });

  if (/⟦PST(?:SEP)?\d+⟧|__970\d{5}__|qzx97\d{5}xzq|<x\s+id=["']pst97\d{5}["']\s*\/?>|\[PST(?:\d{5}|[a-z]+)\]|\*%MISSING%?\s*\*|\uFFFD/iu.test(source) ||
      /\bTODO\b/u.test(source)) {
    failures.push(`translation_artifact=${locale}`);
  }
  if (locale !== 'en-us' && /the original upstream maintainers|PastureStack[- ]Labs/iu.test(source)) {
    failures.push(`unlocalized_upstream_attribution=${locale}`);
  }
  if (/companyLink|\/learn\/|cattle\/adding-services/iu.test(source)) {
    failures.push(`obsolete_translation_link=${locale}`);
  }
  if (locale === 'ja-jp' && !/[ぁ-んァ-ヶ一-龠々]/u.test(source)) {
    failures.push('missing_script=ja-jp');
  }
  if (locale === 'ko-kr' && !/[가-힣]/u.test(source)) {
    failures.push('missing_script=ko-kr');
  }
  if (locale === 'fa-ir' && !/[\u0600-\u06FF]/u.test(source)) {
    failures.push('missing_script=fa-ir');
  }

  Object.entries(requiredValues[locale] || {}).forEach(([key, expected]) => {
    if (leaves[key] !== expected) {
      failures.push(`unexpected_value=${locale}:${key}`);
    }
  });
  if (!String(leaves['nav.noHosts.prefix'] || '').includes(regionalNoHostsFragments[locale])) {
    failures.push(`unnatural_host_warning=${locale}`);
  }
  machineContractKeys.forEach((key) => {
    if (leaves[key] !== englishLeaves[key]) {
      failures.push(`changed_machine_contract=${locale}:${key}`);
    }
  });
});

function filesBelow(directory, extension, result = []) {
  fs.readdirSync(directory, { withFileTypes: true }).forEach((entry) => {
    const fullPath = path.join(directory, entry.name);
    if (entry.isDirectory()) {
      filesBelow(fullPath, extension, result);
    } else if (entry.name.endsWith(extension)) {
      result.push(fullPath);
    }
  });
  return result;
}

function lineNumberAt(source, offset) {
  return source.slice(0, offset).split(/\r?\n/u).length;
}

const allowedLiteralText = /^(?:GB|Mbps|\(CN\)|https:\/\/|ubuntu:\d+\.\d+|alpine:\d+\.\d+)$/iu;
filesBelow(path.join(repoRoot, 'app'), '.hbs').forEach((templatePath) => {
  const relativePath = path.relative(repoRoot, templatePath).replace(/\\/g, '/');
  const rawSource = fs.readFileSync(templatePath, 'utf8');
  const source = rawSource
    .replace(/<!--[\s\S]*?-->/gu, '')
    .replace(/\{\{![\s\S]*?\}\}/gu, '');

  for (const match of source.matchAll(/>([^<]+)</gu)) {
    const residual = match[1]
      .replace(/\{\{[\s\S]*?\}\}/gu, '')
      .replace(/&(?:[A-Za-z][A-Za-z0-9]+|#[0-9]+);/gu, '')
      .trim();
    if (/[A-Za-z]{2,}/u.test(residual) && !allowedLiteralText.test(residual)) {
      failures.push(
        `hardcoded_template_text=${relativePath}:${lineNumberAt(source, match.index)}:${residual.slice(0, 80)}`
      );
    }
  }

  for (const match of source.matchAll(/\b(aria-label|title|alt|placeholder|data-title)="([^"]+)"/gu)) {
    const attribute = match[1];
    const value = match[2];
    if (!/[A-Za-z]{2,}/u.test(value) || value.includes('{{')) {
      continue;
    }
    if (attribute === 'placeholder' && /^[A-Za-z][\w-]*(?:\.[\w-]+)+$/u.test(value)) {
      continue;
    }
    if (value === 'PastureStack') {
      continue;
    }
    failures.push(
      `hardcoded_template_attribute=${relativePath}:${lineNumberAt(source, match.index)}:${attribute}`
    );
  }
});

const footerSource = fs.readFileSync(path.join(repoRoot, 'app', 'components', 'page-footer', 'template.hbs'), 'utf8');
