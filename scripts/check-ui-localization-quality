const applicationRouteSource = fs.readFileSync(path.join(repoRoot, 'app', 'application', 'route.js'), 'utf8');
const adminSettingsSource = fs.readFileSync(path.join(repoRoot, 'app', 'admin-tab', 'settings', 'template.hbs'), 'utf8');

[
  ['footer_forum', footerSource, /forum|slack|wechat/iu],
  ['footer_component_community', footerComponentSource, /forum|slack|wechat/iu],
  ['community_constant', constantsSource, /FORUM|SLACK/],
  ['broken_service_docs', helpSource, /cattle\/adding-services|companyLink|\/learn\//],
  ['footer_visibility_gate', footerSource, /settings\.isRancher/u],
  ['help_visibility_gate', helpSource, /settings\.isRancher/u],
  ['service_docs_visibility_gate', heroAddServiceSource, /settings\.isRancher/u],
  ['language_contribution_visibility_gate', languageDropdownSource, /settings\.isRancher/u],
  ['help_button_visibility_gate', helpButtonSource, /settings\.isRancher/u],
].forEach(([name, source, pattern]) => {
  if (pattern.test(source)) {
    failures.push(`obsolete_reference=${name}`);
  }
});

