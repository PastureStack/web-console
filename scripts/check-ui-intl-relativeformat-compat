#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

lock_path="docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json"

python3 - <<'PY'
import json
import sys
from pathlib import Path

package = json.loads(Path("package.json").read_text(encoding="utf-8"))
lock = json.loads(Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json").read_text(encoding="utf-8"))
packages = lock.get("packages", {})
root = packages.get("node_modules/intl-relativeformat", {})
overrides = package.get("overrides", {})

failures = []

if root.get("version") != "1.3.1-rc16.0":
    failures.append(f"root intl-relativeformat version is {root.get('version')!r}")
if root.get("deprecated"):
    failures.append("root intl-relativeformat still has a deprecated warning")
if root.get("resolved") != "file:vendor/intl-relativeformat-compat/intl-relativeformat-1.3.1-rc16.0.tgz":
    failures.append(f"root intl-relativeformat resolved path is {root.get('resolved')!r}")
if overrides.get("intl-relativeformat") != "$intl-relativeformat":
    failures.append("package override for intl-relativeformat is missing")

nested = [path for path in packages if path.endswith("/node_modules/intl-relativeformat")]
if nested:
    failures.append(f"nested intl-relativeformat copies remain: {nested}")

if failures:
    for failure in failures:
        print(f"UI_INTL_RELATIVEFORMAT_COMPAT_FAIL {failure}")
    print(f"failure_count={len(failures)}")
    sys.exit(1)

print("UI_INTL_RELATIVEFORMAT_COMPAT_OK version=1.3.1-rc16.0")
print("failure_count=0")
PY
