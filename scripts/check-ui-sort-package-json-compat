#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

lock_path="docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json"

python3 - <<'PY'
import json
import sys
from pathlib import Path

failures = 0

def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())

package = json.loads(Path("package.json").read_text(encoding="utf-8"))
lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
dev = package.get("devDependencies", {})
overrides = package.get("overrides", {})
if dev.get("sort-package-json") != "file:vendor/sort-package-json-compat":
    fail(
        "SORT_PACKAGE_JSON_COMPAT_DEV_DEP_UNEXPECTED",
        actual=dev.get("sort-package-json"),
    )
if overrides.get("sort-package-json") != "$sort-package-json":
    fail(
        "SORT_PACKAGE_JSON_COMPAT_OVERRIDE_UNEXPECTED",
        actual=overrides.get("sort-package-json"),
    )

wrapper_manifest = Path("vendor/sort-package-json-compat/package.json")
wrapper_index = Path("vendor/sort-package-json-compat/index.js")
wrapper_license = Path("vendor/sort-package-json-compat/LICENSE")
for required in (wrapper_manifest, wrapper_index, wrapper_license):
    if not required.is_file():
        fail("SORT_PACKAGE_JSON_COMPAT_FILE_MISSING", file=required)

if wrapper_manifest.is_file():
    wrapper = json.loads(wrapper_manifest.read_text(encoding="utf-8"))
    deps = wrapper.get("dependencies", {})
    if wrapper.get("name") != "sort-package-json":
        fail("SORT_PACKAGE_JSON_COMPAT_NAME_UNEXPECTED", actual=wrapper.get("name"))
    if wrapper.get("main") != "index.js":
        fail("SORT_PACKAGE_JSON_COMPAT_MAIN_UNEXPECTED", actual=wrapper.get("main"))
    if deps.get("sort-package-json-upstream") != "npm:sort-package-json@3.6.1":
        fail(
            "SORT_PACKAGE_JSON_COMPAT_UPSTREAM_UNEXPECTED",
            actual=deps.get("sort-package-json-upstream"),
        )

lock = json.loads(lock_path.read_text(encoding="utf-8"))
packages = lock.get("packages", {})
root = packages.get("", {})
if package.get("devDependencies", {}) != root.get("devDependencies", {}):
    fail("SORT_PACKAGE_JSON_COMPAT_LOCK_ROOT_DEV_DEP_DRIFT")
compat = packages.get("node_modules/sort-package-json", {})
upstream = packages.get("node_modules/sort-package-json-upstream", {})
if compat.get("resolved") != "vendor/sort-package-json-compat":
    fail("SORT_PACKAGE_JSON_COMPAT_LOCK_RESOLUTION_UNEXPECTED", actual=compat.get("resolved"))
if upstream.get("version") != "3.6.1":
    fail("SORT_PACKAGE_JSON_UPSTREAM_LOCK_VERSION_UNEXPECTED", actual=upstream.get("version"))
if any(path == "node_modules/globby/node_modules/glob" for path in packages):
    fail("SORT_PACKAGE_JSON_OLD_GLOBBY_GLOB_REINTRODUCED")

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)
print(f"UI_SORT_PACKAGE_JSON_COMPAT_OK wrapper=vendor/sort-package-json-compat upstream=3.6.1 lockfile={lock_path}")
print("Ember CLI 2.18 still receives a CommonJS function export while the underlying sorter resolves through the maintained 3.x package.")
print("failure_count=0")
PY
