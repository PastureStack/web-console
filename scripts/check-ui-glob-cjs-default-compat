#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

lock_path="docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json"

python3 - <<'PY'
import json
import sys
from pathlib import Path

package = json.loads(Path("package.json").read_text(encoding="utf-8"))
lock = json.loads(Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json").read_text(encoding="utf-8"))
packages = lock.get("packages", {})
failures = []

glob_dep = package.get("devDependencies", {}).get("glob")
if glob_dep != "file:vendor/glob-cjs-default-compat/glob-13.0.6.tgz":
    failures.append(f"root glob dependency is {glob_dep!r}")

overrides = package.get("overrides", {})
module_resolver = overrides.get("babel-plugin-module-resolver")
if not isinstance(module_resolver, dict) or module_resolver.get("glob") != "$glob":
    failures.append("babel-plugin-module-resolver glob override is not $glob")

yamljs = overrides.get("yamljs")
if not isinstance(yamljs, dict) or yamljs.get("glob") != "$glob":
    failures.append("yamljs glob override is not $glob")

for owner in (
    "broccoli-kitchen-sink-helpers",
    "ember-cli",
    "ember-intl",
    "formatjs-extract-cldr-data",
):
    owner_override = overrides.get(owner)
    if not isinstance(owner_override, dict) or owner_override.get("glob") != "$glob":
        failures.append(f"{owner} glob override is not $glob")

root_glob = packages.get("node_modules/glob", {})
if root_glob.get("version") != "13.0.6":
    failures.append(f"root glob version is {root_glob.get('version')!r}")
if root_glob.get("resolved") != "file:vendor/glob-cjs-default-compat/glob-13.0.6.tgz":
    failures.append(f"root glob resolved is {root_glob.get('resolved')!r}")

glob_real = packages.get("node_modules/glob-real", {})
if glob_real.get("version") != "13.0.6":
    failures.append(f"glob-real version is {glob_real.get('version')!r}")

legacy_path = "node_modules/babel-plugin-module-resolver/node_modules/glob"
if legacy_path in packages:
    failures.append(f"legacy nested module-resolver glob remains at {packages[legacy_path].get('version')!r}")

for legacy_path in (
    "node_modules/broccoli-kitchen-sink-helpers/node_modules/glob",
    "node_modules/broccoli-templater/node_modules/glob",
    "node_modules/ember-cli/node_modules/glob",
    "node_modules/ember-intl/node_modules/glob",
    "node_modules/formatjs-extract-cldr-data/node_modules/glob",
):
    if legacy_path in packages:
        failures.append(f"legacy owner glob remains at {legacy_path} version={packages[legacy_path].get('version')!r}")

if failures:
    for failure in failures:
        print(f"UI_GLOB_CJS_DEFAULT_COMPAT_FAIL {failure}")
    print(f"failure_count={len(failures)}")
    sys.exit(1)

print("UI_GLOB_CJS_DEFAULT_COMPAT_OK root=13.0.6 wrapper=file:vendor/glob-cjs-default-compat/glob-13.0.6.tgz glob_real=13.0.6")
print("babel-plugin-module-resolver, broccoli-kitchen-sink-helpers, ember-cli, ember-intl, formatjs-extract-cldr-data, and yamljs resolve glob through the root compatibility wrapper.")
print("failure_count=0")
PY
