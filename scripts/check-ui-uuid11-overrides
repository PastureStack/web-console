#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

lock_path="docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json"

python3 - "$lock_path" <<'PY'
import json
import sys
from pathlib import Path

lock_path = Path(sys.argv[1])
failures = 0
expected = "11.1.1"


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
overrides = package.get("overrides", {})
for owner in ("ember-cli", "node-notifier"):
    owner_override = overrides.get(owner, {})
    if not isinstance(owner_override, dict) or owner_override.get("uuid") != expected:
        fail("UI_UUID11_OVERRIDE_DRIFT", owner=owner, actual=owner_override, expected=expected)

if not lock_path.is_file():
    fail("UI_UUID11_LOCK_MISSING", file=lock_path)
else:
    lock = json.loads(lock_path.read_text(encoding="utf-8"))
    packages = lock.get("packages", {})
    uuid_paths = {
        path: info.get("version")
        for path, info in packages.items()
        if path == "node_modules/uuid" or path.endswith("/node_modules/uuid")
    }
    if not uuid_paths:
        fail("UI_UUID11_LOCK_PACKAGE_MISSING")
    for path, version in sorted(uuid_paths.items()):
        if version != expected:
            fail("UI_UUID11_LOCK_VERSION_DRIFT", package=path, actual=version, expected=expected)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_UUID11_OVERRIDES_OK version={expected} lockfile={lock_path}")
print("ember-cli and node-notifier keep their CommonJS uuid.v4 call sites while resolving uuid 11.1.1 in the active no-publish UI graph.")
print("failure_count=0")
PY
