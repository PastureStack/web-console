#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PY'
import json
import sys
from pathlib import Path

failures = 0


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
override = (package.get("overrides", {}) or {}).get("ember-cli-babel", {}) or {}
if not isinstance(override, dict):
    fail("EMBER_CLI_BABEL_OVERRIDE_NOT_OBJECT", actual=override)
else:
    if override.get(".") != "8.3.1":
        fail("EMBER_CLI_BABEL_ROOT_OVERRIDE_UNEXPECTED", actual=override.get("."), expected="8.3.1")
    if override.get("rimraf") != "6.1.3":
        fail("EMBER_CLI_BABEL_RIMRAF_OVERRIDE_UNEXPECTED", actual=override.get("rimraf"), expected="6.1.3")

lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
if not lock_path.is_file():
    fail("MISSING_SASS_REPLACEMENT_LOCK", file=lock_path)
else:
    lock = json.loads(lock_path.read_text(encoding="utf-8"))
    packages = lock.get("packages", {}) or {}
    babel = packages.get("node_modules/ember-cli-babel", {})
    rimraf = packages.get("node_modules/ember-cli-babel/node_modules/rimraf") or packages.get("node_modules/rimraf", {})
    if babel.get("version") != "8.3.1":
        fail("EMBER_CLI_BABEL_LOCK_VERSION_UNEXPECTED", actual=babel.get("version"), expected="8.3.1")
    if rimraf.get("version") != "6.1.3":
        fail("EMBER_CLI_BABEL_RIMRAF_LOCK_VERSION_UNEXPECTED", actual=rimraf.get("version"), expected="6.1.3")
    for removed in [
        "node_modules/ember-cli-babel/node_modules/glob",
        "node_modules/ember-cli-babel/node_modules/inflight",
    ]:
        if removed in packages:
            fail("EMBER_CLI_BABEL_LEGACY_DEPENDENCY_REMAINS", package=removed, version=packages[removed].get("version"))
    package_count = len(packages)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(
    "UI_EMBER_CLI_BABEL_RIMRAF_OVERRIDE_OK "
    f"ember-cli-babel=8.3.1 rimraf=6.1.3 lockfile={lock_path} package_count={package_count}"
)
print("The no-publish Ember Babel build path keeps ember-cli-babel 8.3.1 while resolving maintained rimraf 6.1.3 and removing nested legacy glob/inflight.")
print("failure_count=0")
PY
