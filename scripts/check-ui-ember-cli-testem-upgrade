#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PY'
import json
import sys
from pathlib import Path

failures = 0

def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())

package = json.loads(Path("package.json").read_text(encoding="utf-8"))
dev = package.get("devDependencies", {})
overrides = package.get("overrides", {})
if dev.get("ember-cli") != "2.18.2":
    fail("EMBER_CLI_DECLARATION_UNEXPECTED", actual=dev.get("ember-cli"), expected="2.18.2")
if dev.get("socket.io-client") != "4.8.3":
    fail("SOCKET_IO_CLIENT_DECLARATION_UNEXPECTED", actual=dev.get("socket.io-client"), expected="4.8.3")
if overrides.get("testem") != "3.20.0":
    fail("TESTEM_OVERRIDE_UNEXPECTED", actual=overrides.get("testem"), expected="3.20.0")

lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
if not lock_path.is_file():
    fail("MISSING_PACKAGE_LOCK", file=lock_path)
else:
    lock = json.loads(lock_path.read_text(encoding="utf-8"))
    packages = lock.get("packages", {})
    expected = {
        "node_modules/ember-cli": "2.18.2",
        "node_modules/testem": "3.20.0",
        "node_modules/socket.io": "4.8.3",
        "node_modules/socket.io-client": "4.8.3",
        "node_modules/engine.io": "6.6.7",
        "node_modules/ws": "8.18.3",
    }
    for path, version in expected.items():
        actual = packages.get(path, {}).get("version")
        if actual != version:
            fail("LOCK_VERSION_UNEXPECTED", package=path, actual=actual, expected=version)
    xhr = packages.get("node_modules/xmlhttprequest-ssl", {})
    if xhr and xhr.get("version") != "4.0.0":
        fail("XMLHTTPREQUEST_SSL_LOCK_VERSION_UNEXPECTED", actual=xhr.get("version"), expected="absent_or_4.0.0")
    if "node_modules/xmldom" in packages:
        fail("XMLDOM_STILL_RESOLVED", package="node_modules/xmldom")
    package_count = len(packages)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_EMBER_CLI_TESTEM_UPGRADE_OK ember-cli=2.18.2 testem=3.20.0 socket.io=4.8.3 ws=8.18.3 lockfile={lock_path} package_count={package_count}")
print("This is a no-publish build/test dependency step; broader UI audit and deprecated add-on blockers remain compatibility-gated.")
print("failure_count=0")
PY
