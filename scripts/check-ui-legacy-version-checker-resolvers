#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

lock_path="docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json"

python3 - "$lock_path" <<'PY'
import json
import sys
from pathlib import Path

lock_path = Path(sys.argv[1])
failures = 0
expected = "2.2.0"
override_owners = [
    "ember-cli-pagination",
    "ember-getowner-polyfill",
    "ember-hash-helper-polyfill",
    "ember-resolver",
    "liquid-fire",
]
allowed_legacy_owners = {
    "ember-cli-htmlbars",
}


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
overrides = package.get("overrides", {})

for owner in override_owners:
    owner_override = overrides.get(owner, {})
    if not isinstance(owner_override, dict):
        fail("UI_LEGACY_VERSION_CHECKER_OVERRIDE_SHAPE_INVALID", owner=owner, actual_type=type(owner_override).__name__)
        continue
    if owner_override.get("ember-cli-version-checker") != expected:
        fail(
            "UI_LEGACY_VERSION_CHECKER_OVERRIDE_DRIFT",
            owner=owner,
            actual=owner_override.get("ember-cli-version-checker"),
            expected=expected,
        )

if not lock_path.is_file():
    fail("UI_LEGACY_VERSION_CHECKER_LOCK_MISSING", file=lock_path)
else:
    lock = json.loads(lock_path.read_text(encoding="utf-8"))
    packages = lock.get("packages", {})
    bad_paths = []

    for path, info in sorted(packages.items()):
        if path.endswith("node_modules/ember-cli-version-checker") and info.get("version") == "1.3.1":
            parts = path.split("/")
            owner = parts[1] if len(parts) >= 4 and parts[0] == "node_modules" else ""
            if owner not in allowed_legacy_owners:
                bad_paths.append(path)

    for owner in override_owners:
        if owner == "ember-cli-pagination":
            nested_path = "vendor/ember-cli-pagination/node_modules/ember-cli-version-checker"
        else:
            nested_path = f"node_modules/{owner}/node_modules/ember-cli-version-checker"
        nested = packages.get(nested_path, {})
        if nested.get("version") != expected:
            fail(
                "UI_LEGACY_VERSION_CHECKER_LOCK_DRIFT",
                owner=owner,
                actual=nested.get("version"),
                expected=expected,
            )

    if bad_paths:
        fail("UI_LEGACY_VERSION_CHECKER_1X_RETURNED", paths=",".join(bad_paths))

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_LEGACY_VERSION_CHECKER_RESOLVERS_OK version={expected} lockfile={lock_path}")
print("Legacy Ember addons using the instance checker API now keep the bower-compatible 2.2.0 checker while ember-cli-htmlbars keeps the required 1.x static API.")
print("failure_count=0")
PY
