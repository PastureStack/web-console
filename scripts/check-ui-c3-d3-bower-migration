#!/usr/bin/env bash
set -euo pipefail

repo_root=$(cd "$(dirname "$0")/.." && pwd)
cd "$repo_root"

python3 - <<'PYCHECK'
import json
import re
import sys
from pathlib import Path

failures = 0


def fail(code, **fields):
    global failures
    failures += 1
    details = " ".join(f"{key}={value}" for key, value in fields.items())
    print(f"{code} {details}".rstrip())


package = json.loads(Path("package.json").read_text(encoding="utf-8"))
bower = json.loads(Path("bower.json").read_text(encoding="utf-8"))
build = Path("ember-cli-build.js").read_text(encoding="utf-8")
lock_path = Path("docs/baselines/npm-package-lock.sass-replacement.node24-ignore-scripts.json")
lock = json.loads(lock_path.read_text(encoding="utf-8"))

dev_deps = package.get("devDependencies", {}) or {}
c3_version = "0.4.24"
d3_version = "3.5.17"
if dev_deps.get("c3") != c3_version:
    fail("C3_NPM_DEP_VERSION_UNEXPECTED", actual=dev_deps.get("c3"), expected=c3_version)
if dev_deps.get("d3") != d3_version:
    fail("D3_NPM_DEP_VERSION_UNEXPECTED", actual=dev_deps.get("d3"), expected=d3_version)
if "c3" in (bower.get("dependencies", {}) or {}):
    fail("C3_STILL_IN_BOWER_DEPENDENCIES")
for expected in ["node_modules/d3/d3.js", "node_modules/c3/c3.js", "node_modules/c3/c3.css"]:
    if expected not in build:
        fail("C3_D3_NPM_IMPORT_MISSING", path=expected)
for forbidden in ["bower_components/d3/d3.js", "bower_components/c3/c3.js", "bower_components/c3/c3.css"]:
    if forbidden in build:
        fail("C3_D3_BOWER_IMPORT_STILL_PRESENT", path=forbidden)

packages = lock.get("packages", {}) or {}
root_dev = (packages.get("", {}) or {}).get("devDependencies", {}) or {}
if root_dev.get("c3") != c3_version:
    fail("C3_LOCK_ROOT_VERSION_UNEXPECTED", actual=root_dev.get("c3"), expected=c3_version)
if root_dev.get("d3") != d3_version:
    fail("D3_LOCK_ROOT_VERSION_UNEXPECTED", actual=root_dev.get("d3"), expected=d3_version)
c3_pkg = packages.get("node_modules/c3", {}) or {}
d3_pkg = packages.get("node_modules/d3", {}) or {}
if c3_pkg.get("version") != c3_version:
    fail("C3_LOCK_PACKAGE_VERSION_UNEXPECTED", actual=c3_pkg.get("version"), expected=c3_version)
if d3_pkg.get("version") != d3_version:
    fail("D3_LOCK_PACKAGE_VERSION_UNEXPECTED", actual=d3_pkg.get("version"), expected=d3_version)
if c3_pkg.get("resolved") and f"c3/-/c3-{c3_version}.tgz" not in c3_pkg.get("resolved", ""):
    fail("C3_LOCK_RESOLVED_UNEXPECTED", resolved=c3_pkg.get("resolved"))
if d3_pkg.get("resolved") and f"d3/-/d3-{d3_version}.tgz" not in d3_pkg.get("resolved", ""):
    fail("D3_LOCK_RESOLVED_UNEXPECTED", resolved=d3_pkg.get("resolved"))
c3_deps = c3_pkg.get("dependencies", {}) or {}
if c3_deps.get("d3") != "~3.5.0":
    fail("C3_D3_COMPAT_RANGE_UNEXPECTED", actual=c3_deps.get("d3"), expected="~3.5.0")
for removed in ["node_modules/jsdom", "node_modules/request", "node_modules/forever-agent"]:
    if removed in packages:
        fail("C3_D3_REQUEST_RETIREMENT_PACKAGE_REMAINS", package=removed)

c3_usage_count = 0
d3_usage_count = 0
for root in [Path("app"), Path("addon"), Path("tests"), Path("vendor")]:
    if not root.exists():
        continue
    for path in root.rglob("*.js"):
        text = path.read_text(encoding="utf-8")
        c3_usage_count += len(re.findall(r"\bc3\.generate\(", text))
        d3_usage_count += len(re.findall(r"\bd3\.", text))
if c3_usage_count < 4:
    fail("C3_GLOBAL_USAGE_COUNT_TOO_LOW", actual=c3_usage_count, minimum=4)
if d3_usage_count < 20:
    fail("D3_GLOBAL_USAGE_COUNT_TOO_LOW", actual=d3_usage_count, minimum=20)

modernization = Path("docs/modernization.md").read_text(encoding="utf-8")
for phrase in ["No-Publish Bower c3/d3 Migration Candidate", "No-Publish C3/D3 Request Retirement", f"c3@{c3_version}", f"d3@{d3_version}", "node_modules/c3/c3.js", "node_modules/d3/d3.js"]:
    if phrase not in modernization:
        fail("C3_D3_MIGRATION_DOC_MISSING", phrase=phrase)

node24_smoke = Path("scripts/node24-lock-smoke.js").read_text(encoding="utf-8")
for phrase in [f"expectVersion(\"c3\", \"{c3_version}\")", f"expectVersion(\"d3\", \"{d3_version}\")", "expectMissing(\"request\")", "expectMissing(\"forever-agent\")", "expectMissing(\"jsdom\")", "expectC3D3BrowserGlobals", "c3-d3-global-smoke-ok"]:
    if phrase not in node24_smoke:
        fail("C3_D3_NODE24_LOCK_SMOKE_MISSING", phrase=phrase)

if failures:
    print(f"failure_count={failures}")
    sys.exit(1)

print(f"UI_C3_D3_BOWER_MIGRATION_OK c3={c3_version} d3={d3_version} c3_generate_usages={c3_usage_count} d3_global_usages={d3_usage_count} lock={lock_path}")
print("failure_count=0")
PYCHECK
