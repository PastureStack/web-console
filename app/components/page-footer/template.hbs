<a href="#" class="btn btn-sm btn-link" {{action "showAbout"}} aria-label="{{t 'pageFooter.about' appName=settings.appName}}">{{if settings.rancherVersion settings.rancherVersion (t 'pageFooter.notARelease')}}</a>

{{#if projectId}}
  <a href="{{href-to 'authenticated.project.help' projectId}}" role="button" class="btn btn-sm btn-link">{{t 'pageFooter.help'}}</a>
{{/if}}
<a role="button" class="btn btn-sm btn-link" target="_blank" rel="noopener noreferrer" href="{{settings.docsBase}}">{{t 'pageFooter.documentation'}}</a>
<a role="button" class="btn btn-sm btn-link" target="_blank" rel="noopener noreferrer" href="{{settings.issueUrl}}">{{t 'pageFooter.issues'}}</a>

<div class="pull-right">
  <div class="compose-download inline-block">
    <a class="dropdown-toggle hand btn btn-sm btn-link" data-toggle="dropdown" aria-expanded="false">
      <i class="icon icon-download"></i> {{t 'pageFooter.download.link'}} <i class="icon icon-chevron-down"></i>
    </a>
    <ul class="dropdown-menu dropdown-menu-right text-right" role="menu" style="min-width: 0">
      <li class="dropdown-header">{{t 'pageFooter.download.headerCompose'}} ({{t 'pageFooter.download.deprecated'}})</li>
      <li><a href="{{compose.darwin}}">{{t 'pageFooter.download.mac'}} <i class="icon icon-fw icon-apple"></i></a></li>
      <li><a href="{{compose.windows}}">{{t 'pageFooter.download.windows'}} <i class="icon icon-fw icon-windows"></i></a></li>
      <li><a href="{{compose.linux}}">{{t 'pageFooter.download.linux'}} <i class="icon icon-fw icon-linux"></i></a></li>

      <li class="dropdown-header">{{t 'pageFooter.download.headerCli'}}</li>
      <li><a href="{{cli.darwin}}">{{t 'pageFooter.download.mac'}} <i class="icon icon-fw icon-apple"></i></a></li>
      <li><a href="{{cli.windows}}">{{t 'pageFooter.download.windows'}} <i class="icon icon-fw icon-windows"></i></a></li>
      <li><a href="{{cli.linux}}">{{t 'pageFooter.download.linux'}} <i class="icon icon-fw icon-linux"></i></a></li>
    </ul>
  </div>
</div>
<div class="pull-right">
  {{language-dropdown}}
</div>
