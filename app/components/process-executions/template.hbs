<button class="btn btn-primary btn-sm pull-right" style="position:relative;top:-30px;right:25px;" {{action 'expandChildren'}}>
  {{#if expandAll}}
    <i class="icon icon-minus"></i> {{t 'processExecutions.collapseAll'}}
  {{else}}
    <i class="icon icon-plus"></i> {{t 'processExecutions.expandAll'}}
  {{/if}}
</button>
<a href="{{apiView}}" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm pull-right" style="position:relative;top:-30px;right:40px;">{{t 'action.viewInApi'}}</a>
<table class="grid fixed table table-hover">
  <thead>
    <tr>
      <th>{{t 'generic.name'}}</th>
      <th>{{t 'processExecutions.resourceTypeId'}}</th>
      <th width="150">{{t 'processesPage.list.table.exitReason'}}</th>
      <th width="100">{{t 'processesPage.list.table.startTime'}}</th>
      <th width="100">{{t 'processesPage.list.table.endTime'}}</th>
      <th width="100">{{t 'processesPage.list.table.runTime'}}</th>
    </tr>
  </thead>
  <tbody>
    {{#each execution as |execution|}}
      {{process-execution-rows execution=execution topLevel=true expandAll=expandAll}}
    {{/each}}
  </tbody>
</table>
